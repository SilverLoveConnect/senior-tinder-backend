# ──────────────────────────────────────────────────────────────
# 데이터베이스
# Supabase → Settings → Database → Connection string (URI)
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ──────────────────────────────────────────────────────────────
# JWT 인증
# SECRET_KEY: 랜덤 문자열 (python -c "import secrets; print(secrets.token_hex(32))")
# ──────────────────────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ──────────────────────────────────────────────────────────────
# Supabase
# SUPABASE_URL: https://[PROJECT_REF].supabase.co
# SUPABASE_ANON_KEY: Settings → API → anon/public key
# SUPABASE_SERVICE_ROLE_KEY: Settings → API → service_role key (서버 전용)
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────
# AI 서버 연동
# AI_API_URL: 지수 AI 서버 URL (로컬: http://localhost:8001)
# BACKEND_CALLBACK_URL: AI → 태균 콜백 수신 URL
#   예) http://localhost:8000/internal/ai/photo-result
# ──────────────────────────────────────────────────────────────
AI_API_URL=http://localhost:8001
BACKEND_CALLBACK_URL=http://localhost:8000/internal/ai/photo-result

# ──────────────────────────────────────────────────────────────
# Solapi SMS
# https://console.solapi.com → 개발자 → API Key 관리
# ──────────────────────────────────────────────────────────────
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# ──────────────────────────────────────────────────────────────
# 포트원 V1 (결제)
# https://admin.portone.io → 시스템 설정 → API Keys
# ──────────────────────────────────────────────────────────────
PORTONE_IMP_KEY=
PORTONE_IMP_SECRET=

# ──────────────────────────────────────────────────────────────
# AWS S3 (이미지 업로드)
# ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-northeast-2

# ──────────────────────────────────────────────────────────────
# Firebase (푸시 알림) — 선택
# ──────────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=

# ──────────────────────────────────────────────────────────────
# Sentry (에러 모니터링) — 선택
# ──────────────────────────────────────────────────────────────
SENTRY_DSN=
